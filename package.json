{
  "name": "elkulo_mailer",
  "version": "3.6.0",
  "description": "Slim Framework 4 製のモダンでシンプルなメールフォーム",
  "private": true,
  "scripts": {
    "clean": "rm -rf node_modules package-lock.json && npm install",
    "start": "npm run develop & npm run serve",
    "develop": "webpack --mode development --watch",
    "format": "eslint --fix './public/webpack/src/**/*.js'",
    "build": "webpack --mode production",
    "serve": "php -S localhost:8000 -t ./public",
    "composer:init": "cd mailer/core/ && composer install",
    "composer:update": "cd mailer/core/ && composer update",
    "composer:analyse": "cd mailer/core/ && composer analyse",
    "composer:format": "cd mailer/core/ && composer format",
    "deploy": "sh deploy.sh"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.27.1",
    "@babel/preset-env": "^7.27.2",
    "@babel/runtime": "^7.27.1",
    "babel-loader": "^9.2.1",
    "core-js": "^3.42.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^6.0.0",
    "eslint": "^8.57.1",
    "eslint-webpack-plugin": "^4.2.0",
    "mini-css-extract-plugin": "^2.9.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "sass": "^1.89.0",
    "sass-loader": "^14.2.1",
    "typescript": "^5.8.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "axios": "^1.9.0",
    "bootstrap": "^5.3.6"
  }
}
